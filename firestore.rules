rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner() {
      return request.auth != null
        && request.auth.token.email == 'trents.lawncare.ky@gmail.com';
    }

    match /{document=**} {
      allow read, write: if isOwner();
    }
  }
}
